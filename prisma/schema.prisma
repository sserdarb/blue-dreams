generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Page {
  id              String   @id @default(uuid())
  slug            String
  locale          String
  title           String
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  widgets         Widget[]

  @@unique([slug, locale])
}

model Widget {
  id     String @id @default(uuid())
  type   String
  data   String // Storing JSON as string
  order  Int
  pageId String
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id           String        @id @default(uuid())
  customerName String?
  status       String        @default("active") // active, closed
  visitorId    String? // Unique visitor tracking ID
  visitorInfo  String? // JSON: { country, browser, device, currentPage }
  isOnline     Boolean       @default(true)
  lastActivity DateTime      @default(now())
  adminNote    String? // Admin notes for session
  createdAt    DateTime      @default(now())
  messages     ChatMessage[]
}

model ChatMessage {
  id          String      @id @default(uuid())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender      String // 'user', 'agent', 'bot', 'ai'
  content     String
  isFromAdmin Boolean     @default(false)
  metadata    String? // JSON: { widgetType, uiPayload }
  createdAt   DateTime    @default(now())
}

// ===== AI Concierge Models =====

model AiSettings {
  id                   String   @id @default(uuid())
  systemPrompt         String // AI training text / system instruction
  language             String   @default("tr") // tr, en, de, ru
  tone                 String   @default("friendly") // formal, friendly, casual
  isActive             Boolean  @default(true)
  apiKey               String? // Gemini API Key
  googleSheetId        String? // Google Sheet ID for knowledge base
  whatsappAutoReply    Boolean  @default(false) // WhatsApp chatbot auto-reply toggle
  whatsappSystemPrompt String? // Custom system prompt for WhatsApp bot
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model AiTrainingDocument {
  id        String   @id @default(uuid())
  title     String
  content   String // Document content (extracted text)
  type      String // pdf, txt, url
  filename  String? // Original filename
  createdAt DateTime @default(now())
}

model VisitorAction {
  id         String   @id @default(uuid())
  sessionId  String
  actionType String // attract_attention, send_message, takeover
  payload    String? // JSON payload
  createdAt  DateTime @default(now())
}

model Media {
  id        String   @id @default(uuid())
  url       String
  name      String
  type      String
  createdAt DateTime @default(now())
}

// ===== CMS Models =====

model SiteSettings {
  id               String   @id @default(uuid())
  locale           String   @unique
  siteName         String   @default("Blue Dreams Resort")
  logo             String? // URL to logo image
  favicon          String? // URL to favicon
  phone            String?
  email            String?
  address          String?
  socialLinks      String? // JSON: { facebook, instagram, twitter, youtube }
  footerText       String?
  footerCopyright  String?
  headerStyle      String   @default("default") // default, transparent, dark
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  googleMapsApiKey String?
  // Tax rates (configurable from admin panel)
  vatAccommodation Float    @default(10) // Accommodation KDV %
  taxAccommodation Float    @default(2) // Konaklama vergisi %
  vatFnb           Float    @default(20) // F&B KDV %
}

model MenuItem {
  id        String     @id @default(uuid())
  locale    String
  label     String
  url       String
  target    String     @default("_self") // _self, _blank
  order     Int        @default(0)
  parentId  String?
  parent    MenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id])
  children  MenuItem[] @relation("MenuHierarchy")
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Language {
  id         String   @id @default(uuid())
  code       String   @unique // en, tr, de, ru
  name       String // English, Türkçe, Deutsch, Русский
  nativeName String? // English, Türkçe, Deutsch, Русский
  flag       String? // 🇺🇸, 🇹🇷, 🇩🇪, 🇷🇺 or URL
  isActive   Boolean  @default(true)
  isDefault  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

// ===== CTA Bar Model =====

model CtaBar {
  id              String    @id @default(uuid())
  title           String // Main headline
  subtitle        String? // Secondary text
  buttonText      String? // Button label
  buttonUrl       String? // Button link
  backgroundColor String    @default("#2563eb") // Tailwind blue-600
  textColor       String    @default("#ffffff")
  startDate       DateTime? // Schedule start
  endDate         DateTime? // Schedule end
  isActive        Boolean   @default(false) // Starts disabled
  clickCount      Int       @default(0) // Analytics tracking
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ===== CMS Content Models =====

model Room {
  id          String   @id @default(uuid())
  locale      String // tr, en, de, ru
  title       String
  description String
  image       String // Main image URL
  size        String?
  view        String?
  capacity    String?
  features    String // JSON string array: ["Klima", "Wifi"]
  priceStart  String?
  whyChoose   String? // AI için özel alan: "Neden Bu Odayı Seçmelisiniz?"
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Dining {
  id          String        @id @default(uuid())
  locale      String
  title       String
  type        String // Ana Restoran, A'la Carte, Bar
  description String
  image       String
  images      String? // JSON array for gallery (optional)
  cuisine     String?
  hours       String?
  capacity    String?
  location    String?
  features    String?
  isActive    Boolean       @default(true)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  events      DiningEvent[]
}

model DiningEvent {
  id          String    @id @default(uuid())
  diningId    String
  dining      Dining    @relation(fields: [diningId], references: [id], onDelete: Cascade)
  locale      String
  title       String // e.g. "Türk Gecesi"
  description String?
  date        DateTime?
  time        String? // e.g. "19:00 - 22:00"
  image       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Sport {
  id          String   @id @default(uuid())
  locale      String
  title       String
  description String
  image       String // Main image URL
  images      String? // JSON array for gallery (optional)
  icon        String? // Lucide icon name (optional)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Amenity {
  id          String   @id @default(uuid())
  locale      String
  title       String
  description String?
  icon        String // Lucide icon name or image URL
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MeetingRoom {
  id        String   @id @default(uuid())
  locale    String
  title     String
  area      String
  capacity  String
  height    String
  type      String
  image     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== Spa Models =====

model Spa {
  id             String       @id @default(uuid())
  locale         String       @unique
  title          String       @default("Spa & Wellness")
  customLogo     String? // e.g. Naya Logo URL
  heroImage      String? // Main header image
  whatsappNumber String? // e.g. +905495167801
  whatsappText   String? // e.g. Rezervasyon Yapın
  description1   String?
  description2   String?
  description3   String?
  gallery        String? // JSON array for gallery images
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  services       SpaService[]
}

model SpaService {
  id          String   @id @default(uuid())
  spaId       String
  spa         Spa      @relation(fields: [spaId], references: [id], onDelete: Cascade)
  locale      String
  title       String // e.g. "Taş Masajı"
  description String?
  image       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== Analytics Models =====

model PageView {
  id        String   @id @default(uuid())
  path      String // e.g. /tr, /en/rooms, /tr/admin
  locale    String   @default("tr")
  referrer  String? // Where user came from
  userAgent String?
  country   String?
  device    String? // mobile, desktop, tablet
  browser   String?
  sessionId String? // Cookie-based session tracking
  duration  Int      @default(0) // Time on page in seconds
  createdAt DateTime @default(now())
}

model AnalyticsConfig {
  id             String   @id @default(uuid())
  gaId           String? // GA4 Measurement ID: G-XXXXXXXXXX
  gtmId          String? // Google Tag Manager: GTM-XXXXXXX
  fbPixelId      String? // Facebook Pixel ID
  gaApiSecret    String? // GA4 Data API - API Secret (for server-side)
  gaPropertyId   String? // GA4 Property ID (numeric, for Data API)
  gaServiceKey   String? // GA4 Service Account JSON key (base64 encoded)
  useGaApi       Boolean  @default(false) // If true, pull data from GA4 API instead of internal
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  googleClientId String? // GA4 Client ID (OAuth)
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String? // Optional — Google users don't have a password
  name         String
  role         String    @default("admin") // superadmin, admin, editor, viewer
  permissions  String? // JSON array: ["task_management","workflow_management","mail_management"]
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  googleId     String?   @unique // Google OAuth subject ID
  avatar       String? // Profile picture URL
  authProvider String    @default("local") // "local" or "google"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model PermissionRequest {
  id                   String   @id @default(uuid())
  userId               String // AdminUser requesting
  userEmail            String
  userName             String
  requestedPermissions String // JSON array of requested permissions
  reason               String // Why they need it
  status               String   @default("pending") // pending, approved, rejected
  reviewedBy           String? // AdminUser who reviewed
  reviewNote           String? // Reviewer's note
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ===== Elektra Cache Models (Item 16 & 17) =====

model ElektraReservation {
  id         Int      @id // Elektra Reservation ID
  voucherNo  String?
  agency     String?
  channel    String? // OTA, Website, Call Center, etc.
  boardType  String?
  roomType   String?
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Float
  paidPrice  Float // Often 0 if payment at hotel
  currency   String // TRY, EUR, USD, GBP, etc.
  status     String // Reservation, Cancelled, InHouse, CheckOut, Waiting
  roomCount  Int      @default(1)
  adults     Int      @default(2)
  children   Int      @default(0)
  country    String? // Derived from guests[0].country
  bookedAt   DateTime // Elektra's 'lastUpdate' used as booking time
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([checkIn])
  @@index([bookedAt])
  @@index([status])
}

model ElektraRate {
  date      DateTime @id // Primary key is the date (YYYY-MM-DD)
  eur       Float // EUR to TRY rate on this date
  usd       Float // USD to TRY rate on this date
  gbp       Float?
  fetchedAt DateTime @default(now())
}

model AdminTranslation {
  id     String @id @default(uuid())
  key    String
  locale String
  value  String

  @@unique([key, locale])
}

// ===== Task Management Models =====

model Department {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#3b82f6")
  icon      String   @default("building")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  tasks     Task[]
}

model Task {
  id           String           @id @default(uuid())
  title        String
  description  String?
  status       String           @default("todo") // todo, in_progress, review, done, cancelled
  priority     String           @default("medium") // low, medium, high, urgent
  dueDate      DateTime?
  departmentId String?
  department   Department?      @relation(fields: [departmentId], references: [id])
  assigneeId   String? // AdminUser.id
  creatorId    String // AdminUser.id
  parentId     String? // Sub-task parent
  workflowId   String?
  tags         String? // JSON array
  sourceType   String? // manual, email, ai
  sourceRef    String? // Email message ID or reference
  order        Int              @default(0)
  estimatedMin Int? // Estimated minutes
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  comments     TaskComment[]
  attachments  TaskAttachment[]

  @@index([status])
  @@index([assigneeId])
  @@index([departmentId])
  @@index([dueDate])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String // AdminUser.id
  content   String
  type      String   @default("comment") // comment, status_change, assignment, system
  createdAt DateTime @default(now())
}

model TaskAttachment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  name      String
  url       String
  type      String // file MIME type
  size      Int
  createdAt DateTime @default(now())
}

model Workflow {
  id          String         @id @default(uuid())
  name        String
  description String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  steps       WorkflowStep[]
}

model WorkflowStep {
  id           String   @id @default(uuid())
  workflowId   String
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  assigneeId   String? // Default assignee AdminUser.id
  departmentId String? // Default department
  order        Int      @default(0)
  duration     Int? // Expected duration in minutes
}

model MailIntegration {
  id          String    @id @default(uuid())
  userId      String // AdminUser who configured
  provider    String    @default("imap") // imap, google, outlook
  email       String
  // IMAP settings
  imapHost    String    @default("")
  imapPort    Int       @default(993)
  imapUser    String    @default("")
  imapPass    String    @default("") // encrypted
  imapSsl     Boolean   @default(true)
  // SMTP settings
  smtpHost    String    @default("")
  smtpPort    Int       @default(587)
  smtpUser    String    @default("")
  smtpPass    String    @default("") // encrypted
  smtpSsl     Boolean   @default(true)
  // Status
  isActive    Boolean   @default(true)
  isConnected Boolean   @default(false)
  lastSyncAt  DateTime?
  syncCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String // AdminUser.id
  type      String // task_assigned, task_due, task_comment, workflow_step, email_converted
  title     String
  message   String
  link      String? // Admin panel path
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model ReservationRequest {
  id               String   @id @default(uuid())
  checkIn          DateTime
  checkOut         DateTime
  roomType         String
  roomTypeId       Int      @default(0)
  adults           Int      @default(2)
  children         Int      @default(0)
  currency         String   @default("EUR")
  totalPrice       Float    @default(0)
  guestName        String
  guestSurname     String   @default("")
  guestEmail       String
  guestPhone       String
  guestNationality String   @default("TR")
  specialRequests  String   @default("")
  status           String   @default("pending") // pending, confirmed, cancelled
  source           String   @default("website") // website, concierge, whatsapp
  notes            String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ===== CRM Marketing Models =====

model GuestProfile {
  id             String               @id @default(uuid())
  elektraId      Int?                 @unique
  name           String
  surname        String
  email          String?
  phone          String?
  country        String?
  language       String               @default("tr")
  totalStays     Int                  @default(0)
  totalRevenue   Float                @default(0)
  lastCheckIn    DateTime?
  lastCheckOut   DateTime?
  firstCheckIn   DateTime?
  tags           String? // JSON: ["VIP","Repeat"]
  source         String               @default("elektra") // elektra, website, whatsapp, manual
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  segments       GuestSegmentMember[]
  socialMessages SocialMessage[]

  @@index([phone])
  @@index([country])
  @@index([email])
}

model MarketingSegment {
  id          String               @id @default(uuid())
  name        String
  description String?
  color       String               @default("#3b82f6")
  icon        String               @default("users")
  filterJson  String? // JSON: auto filter rules
  isAutomatic Boolean              @default(false)
  guestCount  Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  members     GuestSegmentMember[]
  campaigns   Campaign[]
}

model GuestSegmentMember {
  id        String           @id @default(uuid())
  guestId   String
  guest     GuestProfile     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  segmentId String
  segment   MarketingSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  addedAt   DateTime         @default(now())

  @@unique([guestId, segmentId])
}

model SocialMessage {
  id          String        @id @default(uuid())
  platform    String        @default("whatsapp") // whatsapp, facebook, instagram
  waMessageId String?       @unique // can act as a general external message ID
  guestId     String?
  guest       GuestProfile? @relation(fields: [guestId], references: [id])
  phone       String? // Make optional since FB/IG might not have a phone number initially
  socialId    String? // FB/IG user ID
  threadId    String? // Group messages by thread/conversation
  direction   String // inbound, outbound
  type        String        @default("text") // text, image, template, campaign, audio, video
  content     String
  templateId  String?
  campaignId  String?
  status      String        @default("received") // received, sent, delivered, read, failed
  metadata    String? // JSON for additional payload (like IG media URLs)
  isFromGuest Boolean       @default(false)
  translated  String? // Store translated version of the message
  createdAt   DateTime      @default(now())

  @@index([phone])
  @@index([socialId])
  @@index([threadId])
  @@index([platform])
  @@index([guestId])
  @@index([createdAt])
  @@index([direction])
}

model Campaign {
  id             String            @id @default(uuid())
  name           String
  type           String // whatsapp, email
  segmentId      String?
  segment        MarketingSegment? @relation(fields: [segmentId], references: [id])
  templateId     String?
  subject        String? // Email subject
  content        String? // Message content
  status         String            @default("draft") // draft, scheduled, sending, sent, cancelled
  scheduledAt    DateTime?
  sentAt         DateTime?
  totalSent      Int               @default(0)
  totalDelivered Int               @default(0)
  totalOpened    Int               @default(0)
  totalClicked   Int               @default(0)
  totalFailed    Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model EmailTemplate {
  id          String   @id @default(uuid())
  name        String
  subject     String
  htmlContent String
  jsonContent String? // Editor state JSON
  category    String   @default("general") // welcome, promo, seasonal, event, feedback
  thumbnail   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WhatsAppTemplate {
  id        String   @id @default(uuid())
  name      String
  content   String // Template text with {{name}} style variables
  category  String   @default("general") // greeting, info, promo, feedback
  language  String   @default("tr")
  isActive  Boolean  @default(true)
  useCount  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== Booking Engine & Payment Models =====

model Booking {
  id          String @id @default(cuid())
  referenceId String @unique // BDR-XXXX format
  status      String @default("pending") // pending, paid, confirmed, cancelled, refunded

  // Misafir
  guestName  String
  guestEmail String
  guestPhone String
  guestNotes String?

  // Rezervasyon
  roomTypeId Int
  roomType   String
  checkIn    DateTime
  checkOut   DateTime
  nights     Int
  adults     Int
  children   Int      @default(0)
  childAges  String? // JSON string e.g. "[3, 7]"

  // Fiyat
  totalPrice Float
  currency   String @default("TRY")

  // Ödeme
  paymentMethod String? // iyzico, paytr
  paymentId     String? // Sağlayıcı ödeme ID
  installments  Int       @default(1)
  paidAt        DateTime?

  // Elektra
  elektraResId  String? // Elektra rezervasyon numarası
  elektraStatus String? // synced, failed, pending

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentLogs PaymentLog[]
}

model PaymentLog {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])

  provider String // iyzico, paytr
  action   String // init, callback, refund
  status   String // success, failed, pending, 3d_redirect
  amount   Float
  currency String

  requestData  String? // JSON string
  responseData String? // JSON string
  errorMessage String?

  ipAddress String?

  createdAt DateTime @default(now())
}

model PaymentSettings {
  id       String @id @default(cuid())
  provider String @unique // 'iyzico' veya 'paytr'

  // API Credentials (Encrypted)
  apiKey       String?
  secretKey    String?
  merchantId   String? // PayTR / VPOS Müşteri No
  merchantSalt String? // PayTR için

  // VPOS / EST fields for banks
  apiUsername String? // Hesap Adı
  apiPassword String? // Parola
  terminalId  String? // Terminal No
  storeKey    String? // Parola (3D)
  entId       String? // Ent.Id

  // Routing rules
  isForeign            Boolean @default(false)
  supportSinglePayment Boolean @default(true)

  mode     String  @default("sandbox") // 'sandbox' veya 'live'
  isActive Boolean @default(false)

  // Komisyon (Peşin ödeme için veya temel oran)
  baseCommissionRate Float @default(0) // Yüzdelik, örn 2.5

  installments PaymentInstallmentRate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentInstallmentRate {
  id                String          @id @default(cuid())
  paymentSettingsId String
  paymentSettings   PaymentSettings @relation(fields: [paymentSettingsId], references: [id], onDelete: Cascade)

  installments   Int // örn: 2, 3, 6, 9, 12
  commissionRate Float // Yüzdelik, örn 4.5

  @@unique([paymentSettingsId, installments])
}
